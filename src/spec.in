Summary: Iozone Filesystem Benchmark
Name: iozone-rh
Version: 3
Release: 508
License: Freeware
Group: Applications/Engineering
Source: %{name}%{version}_%{release}.tar
##Buildroot: /var/tmp/%{name}-buildroot
Buildroot: "%{HOME}/github/iozone/RPM"

%description
IOzone is a filesystem benchmark tool. The benchmark generates and 
measures a variety of file operations. Iozone has been ported to many machines and runs under many operating systems.

Iozone is useful for performing a broad filesystem analysis of a vendors
computer platform. The benchmark tests file I/O performance for the following
operations: Read, write, re-read, re-write, read backwards, read strided,
fread, fwrite, random read, pread ,mmap, aio_read, aio_write.

%global debug_package %{nil}

##
## PREP
##
%prep

##
## SETUP and PATCH
##
%setup -n ${Buildroot}/src/


##
## BUILD
##
##
## BUILD
##
%build
%ifarch %{ix86}
    make linux
%else
    %ifarch x86_64
        make linux-AMD64
    %else
        %ifarch ia64
            make linux-ia64
        %else
            %ifarch ppc
                make  linux-powerpc
            %else
                %ifarch ppc64
                    make linux-powerpc64
                %else
                    %ifarch s390
                        make linux-S390
                    %else
                        %ifarch s390x
                            make linux-S390X
                    	%else
                           %ifarch %(arm)
                               make linux-arm
			   %else
			      echo "No idea how to build for your arch..."
			      exit 1
			   %endif
                        %endif
                    %endif
                %endif
            %endif
        %endif
    %endif
%endif

##
## INSTALL
##
%install
mkdir -p $RPM_BUILD_ROOT/opt/iozone/bin
cp $RPM_BUILD_DIR/src/xiozone $RPM_BUILD_ROOT/opt/iozone/bin/
cp $RPM_BUILD_DIR/src/xfileop $RPM_BUILD_ROOT/opt/iozone/bin/
cp $RPM_BUILD_DIR/src/xpit_server $RPM_BUILD_ROOT/opt/iozone/bin/
cp $RPM_BUILD_DIR/src/xGenerate_Graphs $RPM_BUILD_ROOT/opt/iozone/bin/
cp $RPM_BUILD_DIR/src/xgengnuplot.sh $RPM_BUILD_ROOT/opt/iozone/bin/
cp $RPM_BUILD_DIR/src/xgnu3d.dem $RPM_BUILD_ROOT/opt/iozone/bin/
cp

mkdir -p $RPM_BUILD_ROOT/opt/iozone/docs
cp $RPM_BUILD_DIR/docs/IOzone_msword_98.pdf $RPM_BUILD_ROOT/opt/iozone/docs/
cp $RPM_BUILD_DIR/docs/Run_rules.doc $RPM_BUILD_ROOT/opt/iozone/docs/
cp $RPM_BUILD_DIR/docs/IOzone_msword_98.doc $RPM_BUILD_ROOT/opt/iozone/docs/
cp $RPM_BUILD_DIR/docs/Iozone_ps.gz $RPM_BUILD_ROOT/opt/iozone/docs/
cp $RPM_BUILD_DIR/src/Gnuplot.txt $RPM_BUILD_ROOT/opt/iozone/docs/

mkdir -p $RPM_BUILD_ROOT/opt/iozone/man/man1
cp $RPM_BUILD_DIR/docs/iozone.1 $RPM_BUILD_ROOT/opt/iozone/man/man1/

mkdir -p $RPM_BUILD_ROOT/opt/iozone/templates
cp $RPM_BUILD_DIR/templates/bkwdread.md $RPM_BUILD_ROOT/opt/iozone/templates
cp $RPM_BUILD_DIR/templates/bkwdread.md $RPM_BUILD_ROOT/opt/iozone/templates
cp $RPM_BUILD_DIR/templates/coversheet.md $RPM_BUILD_ROOT/opt/iozone/templates
cp $RPM_BUILD_DIR/templates/fread.md $RPM_BUILD_ROOT/opt/iozone/templates
cp $RPM_BUILD_DIR/templates/freread.md $RPM_BUILD_ROOT/opt/iozone/templates
cp $RPM_BUILD_DIR/templates/frewrite.md $RPM_BUILD_ROOT/opt/iozone/templates
cp $RPM_BUILD_DIR/templates/fwrite.md $RPM_BUILD_ROOT/opt/iozone/templates
cp $RPM_BUILD_DIR/templates/performance-testing.md $RPM_BUILD_ROOT/opt/iozone/templates
cp $RPM_BUILD_DIR/templates/randread.md $RPM_BUILD_ROOT/opt/iozone/templates
cp $RPM_BUILD_DIR/templates/randwrite.md $RPM_BUILD_ROOT/opt/iozone/templates
cp $RPM_BUILD_DIR/templates/read.md $RPM_BUILD_ROOT/opt/iozone/templates
cp $RPM_BUILD_DIR/templates/recrewrite.md $RPM_BUILD_ROOT/opt/iozone/templates
cp $RPM_BUILD_DIR/templates/ReportPage.md $RPM_BUILD_ROOT/opt/iozone/templates
cp $RPM_BUILD_DIR/templates/reread.md $RPM_BUILD_ROOT/opt/iozone/templates
cp $RPM_BUILD_DIR/templates/rewrite.md $RPM_BUILD_ROOT/opt/iozone/templates
cp $RPM_BUILD_DIR/templates/strideread.md $RPM_BUILD_ROOT/opt/iozone/templates
cp $RPM_BUILD_DIR/templates/write.md $RPM_BUILD_ROOT/opt/iozone/templates

mkdir -p $RPM_BUILD_ROOT/opt/iozone/styles
cp $RPM_BUILD_DIR/styles/coversheet.css $RPM_BUILD_ROOT/opt/iozone/styles
cp $RPM_BUILD_DIR/styles/reportpage.css $RPM_BUILD_ROOT/opt/iozone/styles
cp $RPM_BUILD_DIR/styles/stylesheet.css $RPM_BUILD_ROOT/opt/iozone/styles

##
## FILES
##
%files
%attr(755,root,root) /opt/


##
## CLEAN
##
%clean
rm -rf $RPM_BUILD_ROOT
